---
interface DownloadTranslations {
	recommended: string;
	title: string;
	subtitle: string;
	winClient: string;
	winReq: string;
	macClient: string;
	macReq: string;
	btnWinDownload: string;
	btnWinZip: string;
	linuxClient: string;
	linuxReq: string;
	btnLinuxDebian: string;
	btnLinuxRPM: string;
	btnLinuxAUR: string;
	aurCommandCopied: string;
	loading: string;
	androidApp: string;
	androidReq: string;
	btnApk: string;
	bit64: string;
}

interface Props {
	t: DownloadTranslations;
}

const { t } = Astro.props;
const FALLBACK = "https://github.com/LanRhyme/MicYou/releases/latest";
---

<section id="download" class="download-section" data-t={JSON.stringify(t)}>
	<div class="download-content">
		<h2 class="section-title">{t.title}</h2>
		<p class="section-subtitle">{t.subtitle}</p>

		<div class="download-grid">
			<!-- Windows -->
			<div class="download-card" data-platform="windows">
				<div class="badge" hidden>{t.recommended}</div>
				<div class="platform-icon">
					<md-icon>desktop_windows</md-icon>
				</div>
				<h3 class="platform-name">{t.winClient}</h3>
				<p class="platform-desc">{t.winReq}</p>
				<div class="store-buttons">
					<md-outlined-button data-url="exe" href={FALLBACK}>
						<md-icon slot="icon">download</md-icon>
						<span class="btn-label">{t.loading}</span>
					</md-outlined-button>
					<md-outlined-button data-url="zip" href={FALLBACK}>
						<md-icon slot="icon">download</md-icon>
						{t.btnWinZip}
					</md-outlined-button>
				</div>
				<div class="version-info">
					<span class="version-tag">Latest</span> &bull; {t.bit64}
				</div>
			</div>

			<!-- Android -->
			<div class="download-card" data-platform="android">
				<div class="badge" hidden>{t.recommended}</div>
				<div class="platform-icon">
					<md-icon>smartphone</md-icon>
				</div>
				<h3 class="platform-name">{t.androidApp}</h3>
				<p class="platform-desc">{t.androidReq}</p>
				<div class="store-buttons">
					<md-outlined-button data-url="apk" href={FALLBACK}>
						<md-icon slot="icon">android</md-icon>
						{t.btnApk}
					</md-outlined-button>
				</div>
				<div class="version-info">
					<span class="version-tag">Latest</span>
				</div>
			</div>

			<!-- macOS -->
			<div class="download-card" data-platform="mac">
				<div class="badge" hidden>{t.recommended}</div>
				<div class="platform-icon">
					<md-icon>laptop_mac</md-icon>
				</div>
				<h3 class="platform-name">{t.macClient}</h3>
				<p class="platform-desc">{t.macReq}</p>
				<div class="store-buttons">
					<md-outlined-button data-url="dmg-arm" href={FALLBACK}>
						<md-icon slot="icon">download</md-icon>
						macOS (Apple Silicon)
					</md-outlined-button>
					<md-outlined-button data-url="dmg-x64" href={FALLBACK}>
						<md-icon slot="icon">download</md-icon>
						macOS (Intel x64)
					</md-outlined-button>
				</div>
				<div class="version-info">
					<span class="version-tag">Latest</span>
				</div>
			</div>

			<!-- Linux -->
			<div class="download-card" data-platform="linux">
				<div class="badge" hidden>{t.recommended}</div>
				<div class="platform-icon">
					<md-icon>desktop_mac</md-icon>
				</div>
				<h3 class="platform-name">{t.linuxClient}</h3>
				<p class="platform-desc">{t.linuxReq}</p>
				<div class="store-buttons">
					<md-outlined-button data-url="deb" href={FALLBACK}>
						<md-icon slot="icon">download</md-icon>
						{t.btnLinuxDebian}
					</md-outlined-button>
					<md-outlined-button data-url="rpm" href={FALLBACK}>
						<md-icon slot="icon">download</md-icon>
						{t.btnLinuxRPM}
					</md-outlined-button>
					<md-outlined-button data-action="copy-aur">
						<md-icon slot="icon">content_copy</md-icon>
						{t.btnLinuxAUR}
					</md-outlined-button>
				</div>
				<div class="version-info">
					<span class="version-tag">Latest</span> &bull; {t.bit64}
				</div>
			</div>
		</div>
	</div>
</section>

<script>
	import "../scripts/downloadSection.ts";
</script>

<style>
	.download-section {
		padding: 100px 24px;
		background-color: var(--md-sys-color-background);
		position: relative;
		overflow: hidden;
	}

	.download-content {
		max-width: 1000px;
		margin: 0 auto;
		text-align: center;
		position: relative;
		z-index: 2;
	}

	.section-title {
		font-size: 36px;
		font-weight: 700;
		margin-bottom: 16px;
		color: var(--md-sys-color-on-surface);
	}

	.section-subtitle {
		font-size: 18px;
		color: var(--md-sys-color-on-surface-variant);
		margin-bottom: 48px;
		max-width: 600px;
		margin-left: auto;
		margin-right: auto;
	}

	.download-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 32px;
		grid-auto-rows: 1fr;
	}

	.download-card {
		position: relative;
		background: var(--md-sys-color-surface-variant);
		border-radius: 12px;
		padding: 28px;
		display: flex;
		flex-direction: column;
		align-items: center;
		border: 1px solid rgba(0, 0, 0, 0.04);
		transition:
			transform 280ms cubic-bezier(0.2, 0.9, 0.3, 1),
			box-shadow 240ms ease;
		backdrop-filter: blur(6px) saturate(120%);
		box-shadow: var(--md-sys-elevation-level1);
		height: 100%;
	}

	.download-card:hover {
		transform: translateY(-8px);
		box-shadow: var(--md-sys-elevation-level2);
	}

	.download-card.recommended {
		border: 1px solid rgba(63, 123, 255, 0.12);
		box-shadow: var(--md-sys-elevation-level2);
		background: color-mix(
			in srgb,
			var(--md-sys-color-surface-variant),
			var(--md-sys-color-primary) 1%
		);
	}

	.download-card.recommended:hover {
		transform: translateY(-8px);
		box-shadow: var(--md-sys-elevation-level3);
	}

	.badge {
		position: absolute;
		top: 12px;
		right: 12px;
		background: var(--md-sys-color-primary);
		color: var(--md-sys-color-on-primary);
		padding: 6px 10px;
		border-radius: 999px;
		font-size: 12px;
		font-weight: 600;
		box-shadow: 0 8px 20px rgba(32, 64, 128, 0.12);
	}

	.platform-icon {
		color: var(--md-sys-color-primary);
		margin-bottom: 20px;
		width: 64px;
		height: 64px;
		background-color: var(--md-sys-color-secondary-container);
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.platform-icon md-icon {
		--md-icon-size: 36px;
	}

	.platform-name {
		font-size: 24px;
		font-weight: 700;
		margin-bottom: 8px;
		color: var(--md-sys-color-on-surface);
	}

	.platform-desc {
		color: var(--md-sys-color-on-surface-variant);
		margin-bottom: 32px;
	}

	.store-buttons {
		display: flex;
		flex-direction: column;
		gap: 12px;
		width: 100%;
		align-items: stretch;
	}

	@media (min-width: 900px) {
		.download-card .store-buttons {
			flex-direction: row;
			justify-content: center;
			gap: 14px;
			flex-wrap: wrap;
		}

		.download-card .store-buttons > * {
			flex: 1 1 180px;
			min-width: 180px;
			white-space: nowrap;
		}
	}

	.version-info {
		margin-top: auto;
		padding-top: 16px;
		font-size: 12px;
		color: var(--md-sys-color-outline);
	}

	@media (max-width: 768px) {
		.download-grid {
			grid-template-columns: 1fr;
		}
	}
</style>

<style is:global>
	#toast-container {
		position: fixed;
		bottom: 16px;
		right: 16px;
		z-index: 9999;
		display: flex;
		flex-direction: column;
		gap: 8px;
		pointer-events: none;
	}

	.toast {
		position: relative;
		background-color: var(--md-sys-color-inverse-surface);
		color: var(--md-sys-color-inverse-on-surface);
		padding: 14px 16px;
		border-radius: 12px;
		font-size: 14px;
		font-weight: 500;
		letter-spacing: 0.1px;
		box-shadow:
			0 1px 2px rgba(0, 0, 0, 0.3),
			0 1px 3px 1px rgba(0, 0, 0, 0.15);
		opacity: 0;
		transform: translateY(8px) scale(0.95);
		transition:
			opacity 200ms cubic-bezier(0.2, 0, 0, 1),
			transform 200ms cubic-bezier(0.2, 0, 0, 1);
		pointer-events: auto;
		min-width: 180px;
		max-width: 320px;
		text-align: center;
		overflow: hidden;
	}

	.toast.show {
		opacity: 1;
		transform: translateY(0) scale(1);
	}

	.toast-progress {
		position: absolute;
		bottom: 0;
		left: 0;
		height: 3px;
		width: 100%;
		background-color: var(--md-sys-color-primary);
		transform-origin: left;
		animation: toast-progress 3s linear forwards;
		border-radius: 0 0 12px 12px;
	}

	@keyframes toast-progress {
		from {
			transform: scaleX(1);
		}
		to {
			transform: scaleX(0);
		}
	}

	@media (max-width: 480px) {
		#toast-container {
			left: 16px;
			right: 16px;
			bottom: 16px;
		}

		.toast {
			max-width: none;
			width: 100%;
		}
	}
</style>
